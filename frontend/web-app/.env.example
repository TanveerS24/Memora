# Frontend API Configuration Example
# Copy this file to .env and update the values

# API Gateway (main entry point)
REACT_APP_API_BASE_URL=http://YOUR_SERVER_IP:8000/api

# Individual Services (for direct access)
REACT_APP_AUTH_BASE_URL=http://YOUR_SERVER_IP:8001
REACT_APP_PARTNER_BASE_URL=http://YOUR_SERVER_IP:8002
REACT_APP_CHAT_BASE_URL=http://YOUR_SERVER_IP:8003
