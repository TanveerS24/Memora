# ============================================
# Memora - Environment Configuration Example
# Copy this file to .env and update values
# ============================================

# Database Configuration
POSTGRES_URL=YOUR_POSTGRES_URL
POSTGRES_USER=YOUR_POSTGRES_USER
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD
POSTGRES_DB=YOUR_POSTGRES_DB

# JWT Authentication
JWT_SECRET=YOUR_JWT_SECRET_KEY

# ChromaDB (Vector Database)
CHROMA_URL=YOUR_CHROMA_URL

# Ollama (Local LLM)
OLLAMA_URL=YOUR_OLLAMA_URL

# Service URLs (Internal Docker Network)
AUTH_SERVICE_URL=YOUR_AUTH_SERVICE_URL
PARTNER_SERVICE_URL=YOUR_PARTNER_SERVICE_URL
CHAT_SERVICE_URL=YOUR_CHAT_SERVICE_URL
MEMORY_SERVICE_URL=YOUR_MEMORY_SERVICE_URL
RAG_SERVICE_URL=YOUR_RAG_SERVICE_URL
MEDIA_SERVICE_URL=YOUR_MEDIA_SERVICE_URL
INSIGHT_SERVICE_URL=YOUR_INSIGHT_SERVICE_URL
SCHEDULER_SERVICE_URL=YOUR_SCHEDULER_SERVICE_URL

# Service Ports
GATEWAY_PORT=YOUR_GATEWAY_PORT
AUTH_PORT=YOUR_AUTH_PORT
PARTNER_PORT=YOUR_PARTNER_PORT
CHAT_PORT=YOUR_CHAT_PORT
MEMORY_PORT=YOUR_MEMORY_PORT
RAG_PORT=YOUR_RAG_PORT
MEDIA_PORT=YOUR_MEDIA_PORT
INSIGHT_PORT=YOUR_INSIGHT_PORT
SCHEDULER_PORT=YOUR_SCHEDULER_PORT

# Media Storage
MEDIA_STORAGE_PATH=YOUR_MEDIA_STORAGE_PATH

# RAG Configuration
RAG_TOP_K=YOUR_RAG_TOP_K
RAG_CHUNK_SIZE=YOUR_RAG_CHUNK_SIZE
RAG_CHUNK_OVERLAP=YOUR_RAG_CHUNK_OVERLAP

# Memory Configuration
MEMORY_ACTIVE_MONTHS=YOUR_MEMORY_ACTIVE_MONTHS
MEMORY_CHUNK_MIN_TOKENS=YOUR_MEMORY_CHUNK_MIN_TOKENS
MEMORY_CHUNK_MAX_TOKENS=YOUR_MEMORY_CHUNK_MAX_TOKENS

# Love Feed Configuration
LOVE_FEED_HISTORY_SIZE=YOUR_LOVE_FEED_HISTORY_SIZE
